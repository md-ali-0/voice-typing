{
  "name": "bengali-english-voice-typing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Lightweight Windows floating voice typing app for Bengali and English.",
  "scripts": {
    "dev": "vite",
    "tauri:dev": "tauri dev",
    "build": "tsc && vite build && npm run sidecar:build",
    "sidecar:build": "tsc -p sidecar/tsconfig.json",
    "tauri:build": "npm run build && tauri build",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.2",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-global-shortcut": "^2.2.0",
    "@tauri-apps/plugin-opener": "^2.2.6",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
