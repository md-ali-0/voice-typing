{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voice Typing",
  "version": "1.0.0",
  "identifier": "com.xe.voice-typing",
  "build": {
    "beforeDevCommand": "pnpm sidecar:build && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Voice Typing",
        "width": 280,
        "height": 92,
        "minWidth": 280,
        "minHeight": 92,
        "maxWidth": 280,
        "maxHeight": 220,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../sidecar/dist"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
